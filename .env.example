# LiteLLM Proxy — скопируйте в .env и заполните
# cp .env.example .env

# Обязательно: мастер-ключ для админки и выдачи ключей
LITELLM_MASTER_KEY=sk-your-master-key-change-me

# Опционально: шифрование ключей в БД
LITELLM_SALT_KEY=sk-your-salt-key-change-me

# Ключи провайдеров (если используете модели в config.yaml)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
