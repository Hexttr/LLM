generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  apiKey       String?  @map("api_key")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("users")
}
